---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Areel Khan" description="Get in touch with Areel Khan">
  <p class="text-terminal-muted text-sm mb-2">$ ping areel</p>
  <h1 class="text-2xl font-bold text-terminal-accent mb-8">Contact</h1>

  <div class="space-y-6">
    <div class="border-l-2 border-terminal-border pl-4">
      <h2 class="text-lg font-semibold text-terminal-text mb-1">Email</h2>
      <a href="mailto:your.email@gmail.com" class="text-terminal-accent hover:underline">
        your.email@gmail.com
      </a>
    </div>

    <div class="border-l-2 border-terminal-border pl-4">
      <h2 class="text-lg font-semibold text-terminal-text mb-1">Book a chat</h2>
      <p class="text-terminal-muted mb-3">
        Want to chat? Book a 30-minute session with me.
      </p>
      <!--
        Replace with your Google Calendar appointment scheduling link.
        Create one at: calendar.google.com > Settings > Appointment schedules
      -->
      <a
        href="https://calendar.google.com/calendar/appointments/schedules/YOUR_SCHEDULE_ID"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block text-sm border border-terminal-border px-4 py-2 text-terminal-accent hover:bg-terminal-surface transition-colors"
      >
        schedule a meeting &rarr;
      </a>
    </div>
  </div>
</BaseLayout>

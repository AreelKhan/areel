---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<PostLayout title={project.data.title} description={project.data.description} date={project.data.date} tags={project.data.tags}>
  <div class="mb-6">
    <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="text-sm font-medium hover:underline">
      View on GitHub &rarr;
    </a>
  </div>
  <Content />
</PostLayout>

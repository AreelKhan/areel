---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Projects — Areel Khan" description="Projects by Areel Khan">
  <p class="text-terminal-muted text-sm mb-2">$ ls ./projects</p>
  <h1 class="text-2xl font-bold text-terminal-accent mb-8">Projects</h1>
  {projects.length === 0 ? (
    <p class="text-terminal-muted">No projects yet. Check back soon.</p>
  ) : (
    <ul class="space-y-6">
      {projects.map((project) => (
        <li class="border-l-2 border-terminal-border pl-4 hover:border-terminal-accent transition-colors">
          <a href={`/projects/${project.id}`} class="block group">
            <h2 class="text-lg font-semibold text-terminal-text group-hover:text-terminal-accent transition-colors">{project.data.title}</h2>
            <p class="text-terminal-muted text-sm mt-1">{project.data.description}</p>
            <div class="flex gap-4 mt-1 text-xs text-terminal-muted">
              <time datetime={project.data.date.toISOString()}>
                {project.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="text-terminal-accent hover:underline">
                github &rarr;
              </a>
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
	const projects = await getCollection("projects");
	return projects.map((project) => ({
		params: { id: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);

// Find related posts (posts that reference this project)
const allPosts = await getCollection("writings");
const relatedPosts = allPosts
	.filter((post) => post.data.project === project.id)
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
	.slice(0, 3);

// If no related posts, find other projects (excluding current)
const allProjects = await getCollection("projects");
const otherProjects = allProjects
	.filter((p) => p.id !== project.id)
	.slice(0, 3);

const hasRelatedPosts = relatedPosts.length > 0;
const hasOtherProjects = otherProjects.length > 0;
const showBottom = hasRelatedPosts || hasOtherProjects;

const colorMap = {
	purple: {
		border: "border-[#ad46ff]",
		shadow: "shadow-[8px_8px_0px_0px_rgba(168,85,247,0.3)]",
		tagBg: "bg-[rgba(173,70,255,0.2)]",
		tagBorder: "border-[#ad46ff]",
		tagText: "text-[#dab2ff]",
		iconBorder: "border-[#c27aff]",
		iconShadow: "shadow-[3px_3px_0px_0px_rgba(168,85,247,0.5)]",
		iconGradient:
			"background-image: linear-gradient(135deg, #ad46ff 0%, #e60076 100%);",
	},
	indigo: {
		border: "border-[#615fff]",
		shadow: "shadow-[8px_8px_0px_0px_rgba(99,102,241,0.3)]",
		tagBg: "bg-[rgba(97,95,255,0.2)]",
		tagBorder: "border-[#615fff]",
		tagText: "text-[#a3b3ff]",
		iconBorder: "border-[#7c86ff]",
		iconShadow: "shadow-[3px_3px_0px_0px_rgba(99,102,241,0.5)]",
		iconGradient:
			"background-image: linear-gradient(135deg, #615fff 0%, #155dfc 100%);",
	},
} as const;

const c = colorMap[project.data.color];

const gridCols: Record<number, string> = {
	1: "grid-cols-1",
	2: "grid-cols-1 sm:grid-cols-2",
	3: "grid-cols-1 sm:grid-cols-3",
};
---

<Layout title={`${project.data.title} — Areel Khan`}>
  <main class="max-w-5xl mx-auto px-6 pt-12 pb-16">
    <!-- Header -->
    <div class={`bg-[rgba(15,23,43,0.8)] rounded-[10px] border-4 ${c.border} ${c.shadow} p-9`}>
      <!-- Tags -->
      <div class="flex gap-2 mb-6">
        {project.data.tags.map((tag) => (
          <span class={`${c.tagBg} border-2 ${c.tagBorder} rounded-full px-3 py-1 text-xs ${c.tagText}`}>
            {tag}
          </span>
        ))}
      </div>

      <!-- Title -->
      <h1 class="font-serif text-5xl text-[#f1f5f9] mb-4">{project.data.title}</h1>

      <!-- Description -->
      <p class="text-lg text-[#cad5e2] leading-[30px] tracking-tight mb-8">
        {project.data.description}
      </p>

      <!-- Links -->
      <div class="flex gap-4">
        {project.data.github && (
          <a
            href={project.data.github}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-6 py-2.5 rounded-[4px] border-2 border-[#615fff] text-[#f8fafc] text-base tracking-tight hover:bg-[#615fff]/10 transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.341-3.369-1.341-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z" fill="currentColor"/>
            </svg>
            GitHub
          </a>
        )}
        {project.data.demo && (
          <a
            href={project.data.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-6 py-2.5 rounded-[4px] border-2 border-[#c27aff] shadow-[4px_4px_0px_0px_rgba(168,85,247,0.5)] text-[#f8fafc] text-base tracking-tight hover:brightness-110 transition"
            style="background-image: linear-gradient(90deg, #9810fa 0%, #4f39f6 100%);"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Live Demo
          </a>
        )}
      </div>
    </div>

    <!-- Body content -->
    <div class="mt-12 prose prose-invert prose-lg max-w-none prose-headings:font-serif prose-headings:text-[#f1f5f9] prose-p:text-[#cad5e2] prose-p:leading-[30px] prose-p:tracking-tight prose-a:text-[#7c86ff] prose-strong:text-[#f1f5f9] prose-li:text-[#cad5e2] prose-code:text-[#dab2ff]">
      <Content />
    </div>

    <!-- Bottom section: Related posts or Other projects -->
    {showBottom && (
      <div class="mt-20 border-t-4 border-[rgba(173,70,255,0.5)] pt-12">
        {hasRelatedPosts ? (
          <>
            <h2 class="font-serif text-3xl text-[#f1f5f9] mb-8">Related Writings</h2>
            <div class={`grid ${gridCols[relatedPosts.length]} gap-8`}>
              {relatedPosts.map((post) => (
                <a
                  href={`${import.meta.env.BASE_URL}/writings/${post.id}`}
                  class="bg-[rgba(15,23,43,0.8)] rounded-[10px] border-4 border-[rgba(97,95,255,0.5)] shadow-[8px_8px_0px_0px_rgba(99,102,241,0.2)] p-9 flex flex-col gap-4 hover:border-[rgba(97,95,255,0.8)] transition-colors"
                >
                  <div class="flex gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="bg-[rgba(97,95,255,0.2)] border-2 border-[#615fff] rounded-full px-3 py-1 text-xs text-[#a3b3ff]">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h3 class="font-serif text-2xl text-[#f1f5f9]">{post.data.title}</h3>
                  <p class="text-base text-[#90a1b9] tracking-tight leading-[26px]">
                    {post.data.description}
                  </p>
                  <div class="flex items-center gap-4 text-sm text-[#62748e] tracking-tight">
                    <span>{post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</span>
                    <span class="size-1 rounded-full bg-[#62748e]" />
                    <span>{post.data.readTime}</span>
                  </div>
                </a>
              ))}
            </div>
          </>
        ) : hasOtherProjects ? (
          <>
            <h2 class="font-serif text-3xl text-[#f1f5f9] mb-8">Other Projects</h2>
            <div class={`grid ${gridCols[otherProjects.length]} gap-8`}>
              {otherProjects.map((p) => {
                const pc = colorMap[p.data.color];
                return (
                  <a href={`${import.meta.env.BASE_URL}/projects/${p.id}`} class={`bg-[rgba(15,23,43,0.8)] rounded-[10px] border-4 ${pc.border} ${pc.shadow} p-9 flex flex-col gap-4 hover:brightness-110 transition`}>
                    <div class="flex items-start justify-between">
                      <h3 class="font-serif text-2xl text-[#f1f5f9]">{p.data.title}</h3>
                      <div
                        class={`shrink-0 size-10 rounded-[4px] border-2 ${pc.iconBorder} ${pc.iconShadow} flex items-center justify-center`}
                        style={pc.iconGradient}
                      >
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M8.281 12.917C8.206 12.628 8.056 12.365 7.846 12.155C7.635 11.944 7.372 11.794 7.083 11.719L1.971 10.401C1.884 10.376 1.807 10.324 1.752 10.251C1.698 10.179 1.668 10.091 1.668 10C1.668 9.909 1.698 9.821 1.752 9.749C1.807 9.676 1.884 9.624 1.971 9.599L7.083 8.28C7.372 8.206 7.635 8.055 7.845 7.845C8.056 7.635 8.206 7.372 8.281 7.083L9.599 1.971C9.624 1.883 9.676 1.806 9.749 1.751C9.821 1.696 9.909 1.666 10 1.666C10.091 1.666 10.18 1.696 10.252 1.751C10.325 1.806 10.377 1.883 10.402 1.971L11.719 7.083C11.794 7.372 11.944 7.635 12.155 7.846C12.365 8.056 12.628 8.206 12.917 8.281L18.029 9.598C18.117 9.623 18.195 9.675 18.25 9.748C18.305 9.82 18.335 9.909 18.335 10C18.335 10.091 18.305 10.18 18.25 10.252C18.195 10.325 18.117 10.377 18.029 10.402L12.917 11.719C12.628 11.794 12.365 11.944 12.155 12.155C11.944 12.365 11.794 12.628 11.719 12.917L10.401 18.029C10.376 18.117 10.324 18.194 10.251 18.249C10.179 18.304 10.091 18.334 10 18.334C9.909 18.334 9.82 18.304 9.748 18.249C9.675 18.194 9.623 18.117 9.598 18.029L8.281 12.917Z" stroke="#F1F5F9" stroke-width="1.667" stroke-linecap="round" stroke-linejoin="round"/>
                          <path d="M16.667 2.5V5.833" stroke="#F1F5F9" stroke-width="1.667" stroke-linecap="round" stroke-linejoin="round"/>
                          <path d="M18.333 4.167H15" stroke="#F1F5F9" stroke-width="1.667" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </div>
                    </div>
                    <p class="text-[#cad5e2] text-base leading-[26px] tracking-tight">
                      {p.data.description}
                    </p>
                    <div class="flex gap-2">
                      {p.data.tags.map((tag) => (
                        <span class={`${pc.tagBg} border-2 ${pc.tagBorder} rounded-full px-3 py-1 text-xs ${pc.tagText}`}>
                          {tag}
                        </span>
                      ))}
                    </div>
                  </a>
                );
              })}
            </div>
          </>
        ) : null}
      </div>
    )}
  </main>
</Layout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Areel Khan">
  <section class="py-12">
    <p class="text-terminal-muted text-sm mb-2">$ whoami</p>
    <h1 class="text-3xl font-bold mb-4">
      Hey, I'm <span class="text-terminal-accent">Areel</span>.<span class="cursor-blink text-terminal-accent">_</span>
    </h1>
    <p class="text-lg text-terminal-dim mb-8 leading-relaxed">
      Software engineer. Welcome to my corner of the internet.
    </p>
    <div class="flex gap-6 text-sm">
      <a href="/projects" class="text-terminal-accent hover:underline">&gt; ls ./projects</a>
      <a href="/blog" class="text-terminal-accent hover:underline">&gt; cat ./blog</a>
    </div>
  </section>
</BaseLayout>

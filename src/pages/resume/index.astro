---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume — Areel Khan" description="Areel Khan's resume">
  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="text-terminal-muted text-sm mb-2">$ cat ./resume</p>
      <h1 class="text-2xl font-bold text-terminal-accent">Resume</h1>
    </div>
    <a
      href="/resume/areel-khan-resume.pdf"
      download
      class="text-sm border border-terminal-border px-4 py-2 text-terminal-accent hover:bg-terminal-surface transition-colors"
    >
      download .pdf
    </a>
  </div>

  <section class="space-y-8">
    <div class="border-l-2 border-terminal-border pl-4">
      <h2 class="text-lg font-semibold text-terminal-text mb-2">Experience</h2>
      <p class="text-terminal-muted"><!-- Add your experience here --></p>
    </div>
    <div class="border-l-2 border-terminal-border pl-4">
      <h2 class="text-lg font-semibold text-terminal-text mb-2">Education</h2>
      <p class="text-terminal-muted"><!-- Add your education here --></p>
    </div>
    <div class="border-l-2 border-terminal-border pl-4">
      <h2 class="text-lg font-semibold text-terminal-text mb-2">Skills</h2>
      <p class="text-terminal-muted"><!-- Add your skills here --></p>
    </div>
  </section>
</BaseLayout>

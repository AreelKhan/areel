---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog — Areel Khan" description="Blog posts by Areel Khan">
  <p class="text-terminal-muted text-sm mb-2">$ ls ./blog</p>
  <h1 class="text-2xl font-bold text-terminal-accent mb-8">Blog</h1>
  {posts.length === 0 ? (
    <p class="text-terminal-muted">No posts yet. Check back soon.</p>
  ) : (
    <ul class="space-y-6">
      {posts.map((post) => (
        <li class="border-l-2 border-terminal-border pl-4 hover:border-terminal-accent transition-colors">
          <a href={`/blog/${post.id}`} class="block group">
            <h2 class="text-lg font-semibold text-terminal-text group-hover:text-terminal-accent transition-colors">{post.data.title}</h2>
            <p class="text-terminal-muted text-sm mt-1">{post.data.description}</p>
            <time class="text-xs text-terminal-muted" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="mb-8">
      <h1 class="text-2xl font-bold text-terminal-accent mb-2">{title}</h1>
      <div class="text-sm text-terminal-muted flex gap-4">
        <time datetime={date.toISOString()}>
          {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {tags.length > 0 && (
          <div class="flex gap-2">
            {tags.map((tag) => (
              <span class="border border-terminal-border px-2 py-0.5 text-xs text-terminal-dim">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>
    <div class="prose prose-invert prose-purple max-w-none prose-code:text-terminal-accent prose-a:text-terminal-accent prose-headings:text-terminal-text prose-p:text-terminal-dim prose-li:text-terminal-dim prose-strong:text-terminal-text">
      <slot />
    </div>
  </article>
</BaseLayout>

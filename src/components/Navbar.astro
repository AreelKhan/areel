---
const base = import.meta.env.BASE_URL;
---

<nav class="border-b border-[rgba(173,70,255,0.3)]">
  <div class="max-w-5xl mx-auto flex items-center justify-between px-6 h-[84px]">
    <a href={base} class="flex items-center">
      <span class="font-serif text-xl text-[#f1f5f9]">Areel Khan</span>
    </a>

    <div class="flex items-center gap-1 sm:gap-4">
      <a
        href={`${base}/projects`}
        class="border-2 border-[#9810fa] rounded-[4px] px-2 py-1 sm:px-6 sm:py-2 text-[#f8fafc] text-xs sm:text-base tracking-tight hover:bg-[#615fff]/10 transition-colors"
      >
        Projects
      </a>
      <a
        href={`${base}/writings`}
        class="border-2 border-[#9810fa] rounded-[4px] px-2 py-1 sm:px-6 sm:py-2 text-[#f8fafc] text-xs sm:text-base tracking-tight hover:bg-[#615fff]/10 transition-colors"
      >
        Writings
      </a>
      <a
        href={`${base}/contact`}
        class="border-2 border-[#9810fa] rounded-[4px] px-2 py-1 sm:px-6 sm:py-2 text-[#f8fafc] text-xs sm:text-base tracking-tight hover:bg-[#615fff]/10 transition-colors"
      >
        Contact
      </a>
    </div>
  </div>
</nav>

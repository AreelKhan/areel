---

---

<section class="max-w-5xl mx-auto px-6 py-16 border-t-4 border-b-4 border-[rgba(173,70,255,0.5)] mt-16">
  <!-- Section heading -->
  <div class="flex items-end justify-between mb-10">
    <div class="flex items-center gap-3">
      <span class="font-serif text-5xl text-[#7c86ff]">✦</span>
      <h2 class="font-serif text-5xl text-[#f1f5f9]">Current Projects</h2>
    </div>
    <a
      href="/projects"
      class="px-6 py-2.5 rounded-[4px] border-2 border-[#c27aff] shadow-[4px_4px_0px_0px_rgba(168,85,247,0.5)] text-[#f8fafc] text-base tracking-tight hover:brightness-110 transition"
      style="background-image: linear-gradient(90deg, #9810fa 0%, #4f39f6 100%);"
    >
      View all →
    </a>
  </div>

  <!-- Project cards -->
  <div class="grid grid-cols-2 gap-8">
    <!-- Card 1: Neural Network Visualizer -->
    <a href="/projects/neural-network-visualizer" class="bg-[rgba(15,23,43,0.8)] rounded-[10px] border-4 border-[#ad46ff] shadow-[8px_8px_0px_0px_rgba(168,85,247,0.3)] p-9 flex flex-col gap-4 hover:brightness-110 transition">
      <div class="flex items-start justify-between">
        <h3 class="font-serif text-2xl text-[#f1f5f9]">Neural Network Visualizer</h3>
        <div
          class="shrink-0 size-10 rounded-[4px] border-2 border-[#c27aff] shadow-[3px_3px_0px_0px_rgba(168,85,247,0.5)] flex items-center justify-center"
          style="background-image: linear-gradient(135deg, #ad46ff 0%, #e60076 100%);"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8.281 12.917C8.206 12.628 8.056 12.365 7.846 12.155C7.635 11.944 7.372 11.794 7.083 11.719L1.971 10.401C1.884 10.376 1.807 10.324 1.752 10.251C1.698 10.179 1.668 10.091 1.668 10C1.668 9.909 1.698 9.821 1.752 9.749C1.807 9.676 1.884 9.624 1.971 9.599L7.083 8.28C7.372 8.206 7.635 8.055 7.845 7.845C8.056 7.635 8.206 7.372 8.281 7.083L9.599 1.971C9.624 1.883 9.676 1.806 9.749 1.751C9.821 1.696 9.909 1.666 10 1.666C10.091 1.666 10.18 1.696 10.252 1.751C10.325 1.806 10.377 1.883 10.402 1.971L11.719 7.083C11.794 7.372 11.944 7.635 12.155 7.846C12.365 8.056 12.628 8.206 12.917 8.281L18.029 9.598C18.117 9.623 18.195 9.675 18.25 9.748C18.305 9.82 18.335 9.909 18.335 10C18.335 10.091 18.305 10.18 18.25 10.252C18.195 10.325 18.117 10.377 18.029 10.402L12.917 11.719C12.628 11.794 12.365 11.944 12.155 12.155C11.944 12.365 11.794 12.628 11.719 12.917L10.401 18.029C10.376 18.117 10.324 18.194 10.251 18.249C10.179 18.304 10.091 18.334 10 18.334C9.909 18.334 9.82 18.304 9.748 18.249C9.675 18.194 9.623 18.117 9.598 18.029L8.281 12.917Z" stroke="#F1F5F9" stroke-width="1.667" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M16.667 2.5V5.833" stroke="#F1F5F9" stroke-width="1.667" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M18.333 4.167H15" stroke="#F1F5F9" stroke-width="1.667" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
      <p class="text-[#cad5e2] text-base leading-[26px] tracking-tight">
        A real-time visualization tool for deep learning models, showing layer activations and gradients during training.
      </p>
      <div class="flex gap-2">
        <span class="bg-[rgba(173,70,255,0.2)] border-2 border-[#ad46ff] rounded-full px-3 py-1 text-xs text-[#dab2ff]">React</span>
        <span class="bg-[rgba(173,70,255,0.2)] border-2 border-[#ad46ff] rounded-full px-3 py-1 text-xs text-[#dab2ff]">TypeScript</span>
        <span class="bg-[rgba(173,70,255,0.2)] border-2 border-[#ad46ff] rounded-full px-3 py-1 text-xs text-[#dab2ff]">TensorFlow</span>
      </div>
    </a>

    <!-- Card 2: Distributed Task Queue -->
    <a href="/projects/distributed-task-queue" class="bg-[rgba(15,23,43,0.8)] rounded-[10px] border-4 border-[#615fff] shadow-[8px_8px_0px_0px_rgba(99,102,241,0.3)] p-9 flex flex-col gap-4 hover:brightness-110 transition">
      <div class="flex items-start justify-between">
        <h3 class="font-serif text-2xl text-[#f1f5f9]">Distributed Task Queue</h3>
        <div
          class="shrink-0 size-10 rounded-[4px] border-2 border-[#7c86ff] shadow-[3px_3px_0px_0px_rgba(99,102,241,0.5)] flex items-center justify-center"
          style="background-image: linear-gradient(135deg, #615fff 0%, #155dfc 100%);"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3.75 13.75C2.5 14.8 2.083 17.917 2.083 17.917C2.083 17.917 5.2 17.5 6.25 16.25C6.842 15.55 6.833 14.475 6.175 13.825C5.851 13.516 5.424 13.337 4.977 13.323C4.529 13.31 4.092 13.461 3.75 13.75Z" stroke="#F1F5F9" stroke-width="1.667" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M10 12.5L7.5 10C7.943 8.85 8.502 7.747 9.167 6.708C10.138 5.156 11.49 3.878 13.094 2.995C14.699 2.113 16.502 1.655 18.333 1.667C18.333 3.933 17.683 7.917 13.333 10.833C12.281 11.499 11.164 12.057 10 12.5Z" stroke="#F1F5F9" stroke-width="1.667" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M7.5 10H3.333C3.333 10 3.792 7.475 5 6.667C6.35 5.767 9.167 6.667 9.167 6.667" stroke="#F1F5F9" stroke-width="1.667" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M10 12.5V16.667C10 16.667 12.525 16.208 13.333 15C14.233 13.65 13.333 10.833 13.333 10.833" stroke="#F1F5F9" stroke-width="1.667" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
      <p class="text-[#cad5e2] text-base leading-[26px] tracking-tight">
        A high-performance task queue system built with Rust, capable of handling millions of tasks per second.
      </p>
      <div class="flex gap-2">
        <span class="bg-[rgba(97,95,255,0.2)] border-2 border-[#615fff] rounded-full px-3 py-1 text-xs text-[#a3b3ff]">Rust</span>
        <span class="bg-[rgba(97,95,255,0.2)] border-2 border-[#615fff] rounded-full px-3 py-1 text-xs text-[#a3b3ff]">Redis</span>
        <span class="bg-[rgba(97,95,255,0.2)] border-2 border-[#615fff] rounded-full px-3 py-1 text-xs text-[#a3b3ff]">gRPC</span>
      </div>
    </a>
  </div>

</section>
